{
	"$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
	"formatter": {
		"bracketSameLine": true,
		"enabled": true,
		"indentStyle": "tab",
		"lineEnding": "crlf"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"style": {
				"useNamingConvention": "off",
				"noDefaultExport": "off"
			},
			"suspicious": {
				"noReactSpecificProps": "off",
				"noEmptyBlockStatements": "off"
			},
			"complexity": {
				"noExcessiveCognitiveComplexity": "off"
			},
			"correctness": {
				"noChildrenProp": "off"
			}
		}
	},
	"files": {
		"ignoreUnknown": true
	}
}
